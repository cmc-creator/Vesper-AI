# =============================================================================
# VESPER AI - LOCAL FREEDOM CONFIG
# =============================================================================
# Copy this to .env (same folder as this file) and fill in your keys.
# This is the LOCAL setup — Vesper runs on YOUR machine, under YOUR rules.
#
# To activate:
#   Windows: copy .env.local.example .env
#   Then edit .env with your actual keys.
# =============================================================================


# =============================================================================
# AI PROVIDERS — at least one required for Vesper to think
# Vesper tries them in order: Groq → Gemini → OpenAI → Anthropic → Ollama
# Groq and Gemini both have FREE tiers — no credit card needed.
# =============================================================================

# Groq (FREE tier: 14,400 req/day, Llama 3.3 70B — FASTEST, start here)
# Get key: https://console.groq.com/keys
GROQ_API_KEY=

# Google Gemini (FREE tier: 1,500 req/day, 1M tokens/day)
# Get key: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# Anthropic Claude (paid — used as fallback if others fail)
# Get key: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI GPT (paid — optional fallback)
OPENAI_API_KEY=

# Image generation via OpenAI DALL-E (optional — uses OPENAI_API_KEY above)
# Set OPENAI_API_KEY and Vesper can generate images with generate_image tool

# =============================================================================
# VESPER AUTONOMY FLAGS — unlock her full capabilities locally
# =============================================================================

# Full shell access — Vesper can run any command without asking for approval
# (except permanently destructive ones like rm/format/shutdown)
# Set to true to give Vesper full shell freedom locally
VESPER_AUTONOMOUS=true

# One-step git shipping — when true, git_commit auto-pushes after successful commit
# Defaults to true when VESPER_AUTONOMOUS=true
VESPER_GIT_AUTOPUSH=true

# Ship policy gate — block push when preflight checks fail
VESPER_SHIP_ENFORCE_CHECKS=true
# Optional stricter policy: require frontend build to pass before push
VESPER_SHIP_REQUIRE_FRONTEND_BUILD=false
# Optional auto-create GitHub issue when ship is blocked
VESPER_SHIP_AUTOCREATE_ISSUE=false

# Daily maintenance loop
VESPER_MAINTENANCE_ENABLED=true
VESPER_MAINTENANCE_HOURS=24
# If true, run self-heal before final empty-response fallback
VESPER_AUTO_SELF_HEAL_ON_EMPTY=true

# Desktop control — Vesper can take screenshots, open apps, click, type
# Requires: pip install pyautogui pyperclip (auto-installs if asked)
DESKTOP_CONTROL_ENABLED=true

# Proactive heartbeat — how often Vesper checks in (minutes)
# She'll send a proactive message when you've been quiet for 1+ hour
# Set to 0 to disable
VESPER_HEARTBEAT_MINUTES=20

# Prefer local Ollama AI first (privacy mode — no cloud calls)
# Requires Ollama installed: https://ollama.ai
# Run: ollama pull llama3.2 to get a model first
OLLAMA_PRIMARY=false

# =============================================================================
# VOICE (ElevenLabs TTS — Vesper's spoken voice)
# Get free key: https://elevenlabs.io (10,000 chars/month free)
# =============================================================================
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# =============================================================================
# EMAIL (optional — gives Vesper ability to send emails)
# Resend is free (100/day): https://resend.com
# =============================================================================
RESEND_API_KEY=
RESEND_FROM_EMAIL=vesper@yourdomain.com

# Alternative: Brevo (300/day free): https://brevo.com
BREVO_API_KEY=
BREVO_FROM_EMAIL=

# =============================================================================
# REVIEWS & RESEARCH (optional)
# =============================================================================

# SerpAPI — Google Reviews, Search Results, Maps data
# Free tier: 100 searches/month — https://serpapi.com
SERPAPI_KEY=

# Google Places API — for detailed Google Maps reviews
# Enable "Places API" on your existing Google Cloud project
GOOGLE_PLACES_API_KEY=

# =============================================================================
# HUMAN EXPERIENCE APIs (all free tiers)
# =============================================================================

# NASA — space images, video library (30 req/hour free with DEMO_KEY, more with real key)
# Get free key: https://api.nasa.gov/
NASA_API_KEY=DEMO_KEY

# TMDB — movies and TV show data
# Free key: https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# Spotify — music search and recommendations
# Free: https://developer.spotify.com/dashboard → Create App
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Ticketmaster — local events (concerts, sports, arts)
# Free: https://developer.ticketmaster.com/
TICKETMASTER_KEY=

# NewsAPI — news monitoring and market intelligence
# Free 100/day: https://newsapi.org
NEWS_API_KEY=

# Hunter.io — find professional emails for lead gen
# Free 25/month: https://hunter.io
HUNTER_API_KEY=

# Yelp Fusion — business search and ratings
# Free: https://www.yelp.com/developers/v3/manage_app
YELP_API_KEY=

# =============================================================================
# CREATIVE INCOME APIs
# =============================================================================

# Gumroad — sell digital products (ebooks, templates, art)
# Free account + token: gumroad.com → Settings → Advanced → Applications
GUMROAD_ACCESS_TOKEN=

# Medium — publish articles for thought leadership + Partner Program income
# Free token: medium.com/me/settings → Security and Apps → Integration tokens
MEDIUM_TOKEN=

# DistroKid / TuneCore — music distribution (no API, manual upload)
# Sign up: distrokid.com ($22/year unlimited songs)
# After Vesper creates a song, upload to DistroKid → Spotify, Apple Music, Amazon Music

# Redbubble / Society6 / Merch by Amazon — art sales (no API, manual upload)
# After Vesper creates art, upload to redbubble.com (free)

# =============================================================================
# SOCIAL MEDIA (optional — Vesper can post on your behalf)
# =============================================================================
LINKEDIN_ACCESS_TOKEN=
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# =============================================================================
# STRIPE (optional — Vesper can create invoices and payment links)
# =============================================================================
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# =============================================================================
# GITHUB (optional — Vesper can commit, push, create issues)
# Get token: https://github.com/settings/tokens
# Scopes needed: repo, workflow
# =============================================================================
GITHUB_TOKEN=
GITHUB_DEFAULT_REPO=cmc-creator/Vesper-AI

# =============================================================================
# GOOGLE WORKSPACE (optional — Drive, Docs, Sheets, Calendar)
# Requires a service account JSON file
# =============================================================================
GOOGLE_SERVICE_ACCOUNT_KEY=
# OR path to service account JSON:
# GOOGLE_SERVICE_ACCOUNT_PATH=./google-service-account.json

# =============================================================================
# DATABASE (local SQLite is auto-created — no setup needed)
# Leave DATABASE_URL empty for local SQLite
# Set to postgres URL only if you want Railway/cloud persistence
# =============================================================================
# DATABASE_URL=postgresql://user:pass@host/dbname

# =============================================================================
# MISC
# =============================================================================
PORT=8000
